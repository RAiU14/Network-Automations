# Default PostgreSQL cache database.
# Docker Compose uses the postgres service hostname internally.
EOX_DATABASE_URL=postgresql+psycopg://eox_user:eox_password@postgres:5432/eox_cache

# Runtime state and preset location inside the backend container.
EOX_DATA_DIR=/product/data
EOX_LOG_DIR=/product/logs

# Optional: stable Fernet key for encrypting Cisco API credentials saved from the GUI.
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# EOX_SECRET_KEY=

# Optional Cisco API defaults. The GUI setup screen can save these later.
# CISCO_CLIENT_ID=
# CISCO_CLIENT_SECRET=
# CISCO_ACCESS_TOKEN=
CISCO_API_BASE_URL=https://apix.cisco.com
CISCO_TOKEN_URL=https://id.cisco.com/oauth2/default/v1/token

# React dev origins
EOX_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:3000,http://localhost:3000
